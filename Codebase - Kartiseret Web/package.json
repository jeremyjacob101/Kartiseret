{
  "name": "Kartiseret Web",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p config/tsconfig.node.json && vite build --config config/vite.config.ts",
    "lint": "eslint .",
    "format": "prettier --ignore-path ../.gitignore --cache --write \"**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\"",
    "format:check": "prettier --ignore-path ../.gitignore --check \"**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\"",
    "preview": "vite preview --config config/vite.config.ts"
  },
  "prettier": {
    "plugins": [
      "./config/prettier-plugin-single-line-imports.mjs"
    ],
    "singleLineImports": true,
    "overrides": [
      {
        "files": [
          "**/*.{js,jsx,cjs,mjs}"
        ],
        "options": {
          "parser": "imports-babel"
        }
      },
      {
        "files": [
          "**/*.{ts,tsx,cts,mts}"
        ],
        "options": {
          "parser": "imports-typescript"
        }
      }
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "lucide-react": "^1.23.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}
