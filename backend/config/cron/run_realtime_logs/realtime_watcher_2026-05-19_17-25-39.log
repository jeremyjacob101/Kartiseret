ges/M/MV5BNjY2ZGEwYTctNTY2Yy00MWRiLThkZDAtZDViYWZkODU0YjA3XkEyXkFqcGc@._V1_PT3.0_CR196,127,2171,3257_.jpg\",\"width\":2171,\"height\":3257,\"__typename\":\"Image\"},\"__typename\":\"Name\"},\"creditedRoles\":{\"edges\":[{\"node\":{\"category\":{\"categoryId\":\"amzn1.imdb.concept.name_credit_category.a9ab2a8b-9153-4edb-a27a-7c2346830d77\",\"text\":\"Actor\",\"__typename\":\"CreditCategory\"},\"attributes\":null,\"characters\":{\"edges\":[{\"node\":{\"name\":\"Ray Elliott\",\"__typename\":\"Character\"},\"__typename\":\"CharacterEdge\"}],\"__typename\":\"CharacterConnection\"},\"__typename\":\"CreditedRole\"},\"__typename\":\"CreditedRoleEdge\"}],\"__typename\":\"CreditedRoleConnection\"},\"episodeCredits\":{\"total\":0,\"yearRange\":null,\"__typename\":\"EpisodeCreditConnection\"},\"__typename\":\"CreditV2\"},{\"name\":{\"id\":\"nm5626530\",\"nameText\":{\"text\":\"Tim Ross\",\"__typename\":\"NameText\"},\"primaryImage\":{\"url\":\"https://m.media-amazon.com/images/M/MV5BZTcwN2YzMDQtZmI1Ny00OWVlLTgzZGYtZmFmNWVhYzM4ZTBiXkEyXkFqcGc@._V1_CR280,0,2797,4196_.jpg\",\"width\":2797,\"height\":4196,\"__typename\":\"Image\"},\"__typename\":\"Name\"},\"creditedRoles\":{\"edges\":[{\"node\":{\"category\":{\"categoryId\":\"amzn1.imdb.concept.name_credit_category.a9ab2a8b-9153-4edb-a27a-7c2346830d77\",\"text\":\"Actor\",\"__typename\":\"CreditCategory\"},\"attributes\":null,\"characters\":{\"edges\":[{\"node\":{\"name\":\"Hancock's First Officer\",\"__typename\":\"Character\"},\"__typename\":\"CharacterEdge\"}],\"__typename\":\"CharacterConnection\"},\"__typename\":\"CreditedRole\"},\"__typename\":\"CreditedRoleEdge\"}],\"__typename\":\"CreditedRoleConnection\"},\"episodeCredits\":{\"total\":0,\"yearRange\":null,\"__typename\":\"EpisodeCreditConnection\"},\"__typename\":\"CreditV2\"},{\"name\":{\"id\":\"nm5259550\",\"nameText\":{\"text\":\"Antonio Alvarez\",\"__typename\":\"NameText\"},\"primaryImage\":{\"url\":\"https://m.media-amazon.com/images/M/MV5BNmQ4NzdhZjgtNWE2MC00MDJmLTkxMjAtYTZhOWVjMzlkYzEzXkEyXkFqcGc@._V1_CR240,0,1903,2855_.jpg\",\"width\":1903,\"height\":2855,\"__typename\":\"Image\"},\"__typename\":\"Name\"},\"creditedRoles\":{\"edges\":[{\"node\":{\"category\":{\"categoryId\":\"amzn1.imdb.concept.name_credit_category.a9ab2a8b-9153-4edb-a27a-7c2346830d77\",\"text\":\"Actor\",\"__typename\":\"CreditCategory\"},\"attributes\":null,\"characters\":{\"edges\":[{\"node\":{\"name\":\"Governor of the Galapagos\",\"__typename\":\"Character\"},\"__typename\":\"CharacterEdge\"}],\"__typename\":\"CharacterConnection\"},\"__typename\":\"CreditedRole\"},\"__typename\":\"CreditedRoleEdge\"}],\"__typename\":\"CreditedRoleConnection\"},\"episodeCredits\":{\"total\":0,\"yearRange\":null,\"__typename\":\"EpisodeCreditConnection\"},\"__typename\":\"CreditV2\"},{\"name\":{\"id\":\"nm9485767\",\"nameText\":{\"text\":\"Benjamin Gorroño\",\"__typename\":\"NameText\"},\"primaryImage\":null,\"__typename\":\"Name\"},\"creditedRoles\":{\"edges\":[{\"node\":{\"category\":{\"categoryId\":\"amzn1.imdb.concept.name_credit_category.a9ab2a8b-9153-4edb-a27a-7c2346830d77\",\"text\":\"Actor\",\"__typename\":\"CreditCategory\"},\"attributes\":[{\"text\":\"as Benjamin Gorrono\",\"__typename\":\"CreditedAsCreditAttribute\"}],\"characters\":{\"edges\":[{\"node\":{\"name\":\"Governor's Translator\",\"__typename\":\"Character\"},\"__typename\":\"CharacterEdge\"}],\"__typename\":\"CharacterConnection\"},\"__typename\":\"CreditedRole\"},\"__typename\":\"CreditedRoleEdge\"}],\"__typename\":\"CreditedRoleConnection\"},\"episodeCredits\":{\"total\":0,\"yearRange\":null,\"__typename\":\"EpisodeCreditConnection\"},\"__typename\":\"CreditV2\"},{\"name\":{\"id\":\"nm7489400\",\"nameText\":{\"text\":\"Nicholas Burton\",\"__typename\":\"NameText\"},\"primaryImage\":null,\"__typename\":\"Name\"},\"creditedRoles\":{\"edges\":[{\"node\":{\"category\":{\"categoryId\":\"amzn1.imdb.concept.name_credit_category.a9ab2a8b-9153-4edb-a27a-7c2346830d77\",\"text\":\"Actor\",\"__typename\":\"CreditCategory\"},\"attributes\":[{\"text\":\"uncredited\",\"__typename\":\"MiscellaneousCreditAttribute\"}],\"characters\":{\"edges\":[{\"node\":{\"name\":\"Hancock Crew\",\"__typename\":\"Character\"},\"__typename\":\"CharacterEdge\"}],\"__typename\":\"CharacterConnection\"},\"__typename\":\"CreditedRole\"},\"__typename\":\"CreditedRoleEdge\"}],\"__typename\":\"CreditedRoleConnection\"},\"episodeCredits\":{\"total\":0,\"yearRange\":null,\"__typename\":\"EpisodeCreditConnection\"},\"__typename\":\"CreditV2\"},{\"name\":{\"id\":\"nm2205614\",\"nameText\":{\"text\":\"Austin Hayden\",\"__typename\":\"NameText\"},\"primaryImage\":{\"url\":\"https://m.media-amazon.com/images/M/MV5BYTg3YWVhNmUtYzc5MC00NmY0LTk2MDEtMDA5NTViOGM3MTljXkEyXkFqcGc@._V1_.jpg\",\"width\":1890,\"height\":2834,\"__typename\":\"Image\"},\"__typename\":\"Name\"},\"creditedRoles\":{\"edges\":[{\"node\":{\"category\":{\"categoryId\":\"amzn1.imdb.concept.name_credit_category.a9ab2a8b-9153-4edb-a27a-7c2346830d77\",\"text\":\"Actor\",\"__typename\":\"CreditCategory\"},\"attributes\":[{\"text\":\"uncredited\",\"__typename\":\"MiscellaneousCreditAttribute\"}],\"characters\":{\"edges\":[{\"node\":{\"name\":\"American Sailor\",\"__typename\":\"Character\"},\"__typename\":\"CharacterEdge\"}],\"__typename\":\"CharacterConnection\"},\"__typename\":\"CreditedRole\"},\"__typename\":\"CreditedRoleEdge\"}],\"__typename\":\"CreditedRoleConnection\"},\"episodeCredits\":{\"total\":0,\"yearRange\":null,\"__typename\":\"EpisodeCreditConnection\"},\"__typename\":\"CreditV2\"}],\"__typename\":\"PrincipalCreditsForGrouping\"}],\"crewV2\":[{\"totalCredits\":1,\"grouping\":{\"groupingId\":\"amzn1.imdb.concept.name_credit_category.ace5cb4c-8708-4238-9542-04641e7c8171\",\"text\":\"Director\",\"__typename\":\"CreditGrouping\"},\"credits\":[{\"name\":{\"id\":\"nm0000165\",\"nameText\":{\"text\":\"Ron Howard\",\"__typename\":\"NameText\"},\"__typename\":\"Name\"},\"__typename\":\"CreditV2\"}],\"__typename\":\"PrincipalCreditsForGrouping\"},{\"totalCredits\":2,\"grouping\":{\"groupingId\":\"amzn1.imdb.concept.name_credit_category.c84ecaff-add5-4f2e-81db-102a41881fe3\",\"text\":\"Writers\",\"__typename\":\"CreditGrouping\"},\"credits\":[{\"name\":{\"id\":\"nm3300218\",\"nameText\":{\"text\":\"Noah Pink\",\"__typename\":\"NameText\"},\"__typename\":\"Name\"},\"__typename\":\"CreditV2\"},{\"name\":{\"id\":\"nm0000165\",\"nameText\":{\"text\":\"Ron Howard\",\"__typename\":\"NameText\"},\"__typename\":\"Name\"},\"__typename\":\"CreditV2\"}],\"__typename\":\"PrincipalCreditsForGrouping\"}],\"titleText\":{\"text\":\"Eden\",\"__typename\":\"TitleText\"},\"originalTitleText\":{\"text\":\"Eden\",\"__typename\":\"TitleText\"},\"canRate\":{\"isRatable\":true,\"__typename\":\"CanRate\"},\"reviews\":{\"total\":198,\"__typename\":\"ReviewsConnection\"},\"aggregateRatingsBreakdown\":{\"histogram\":{\"histogramValues\":[{\"rating\":1,\"voteCount\":999,\"__typename\":\"HistogramValues\"},{\"rating\":2,\"voteCount\":468,\"__typename\":\"HistogramValues\"},{\"rating\":3,\"voteCount\":756,\"__typename\":\"HistogramValues\"},{\"rating\":4,\"voteCount\":1519,\"__typename\":\"HistogramValues\"},{\"rating\":5,\"voteCount\":4274,\"__typename\":\"HistogramValues\"},{\"rating\":6,\"voteCount\":11576,\"__typename\":\"HistogramValues\"},{\"rating\":7,\"voteCount\":14515,\"__typename\":\"HistogramValues\"},{\"rating\":8,\"voteCount\":6638,\"__typename\":\"HistogramValues\"},{\"rating\":9,\"voteCount\":1802,\"__typename\":\"HistogramValues\"},{\"rating\":10,\"voteCount\":2149,\"__typename\":\"HistogramValues\"}],\"__typename\":\"Histogram\"},\"__typename\":\"AggregateRatingsBreakdown\"},\"featuredReviews\":{\"edges\":[{\"node\":{\"id\":\"rw10035870\",\"author\":{\"userId\":\"ur54207336\",\"profileId\":\"p.sc5t2bxb4ucje5gly7qxvnntei\",\"username\":{\"text\":\"Blue-Grotto\",\"__typename\":\"UserProfileUsername\"},\"primaryImage\":{\"image\":{\"url\":\"https://m.media-amazon.com/images/M/MV5BMTU5NjAwMzg2OV5BMl5BanBnXkFtZTgwNTk3OTkyMjE@._V1_.jpg\",\"height\":338,\"width\":338,\"caption\":{\"plainText\":\"Avatar\",\"__typename\":\"Markdown\"},\"__typename\":\"Image\"},\"__typename\":\"UserProfileImage\"},\"__typename\":\"UserProfile\"},\"summary\":{\"originalText\":\"Hell is other people\",\"__typename\":\"ReviewSummary\"},\"text\":{\"originalText\":{\"plaidHtml\":\"An uninhabited island in the Galápagos is paradise and hell at the same time for a trio of couples who settled there in 1929. At one of the remotest areas on earth there is a clash of personalities; philosophical, libertine, and practical. While one couple seeks solitude, another wants to build a luxury hotel, and the third desires a nourishing place for family. As bugs and boars bite hard, and food and water become as scarce as doctors, police, and dentists, each couple is in for a shock. Darwin would be pleased, for on the island that gave him his fame it is survival of fittest all over again.\\u003cbr/\\u003e\\u003cbr/\\u003eIn this true story it is intriguing to see the starkly different personalities battle it out like in a miniature world. Ron Howard who was present at this screening at the Toronto International Film Festival, was captivated by the zany stories of the characters, and the good and bad of each of them. If anything, he said, he had to dial the antics back. It is hard to choose a side. Jude Law and the other actors are capable and convincing. Hans Zimmer orchestrated the playlist. How many soundtracks can one person do? I wish there was a little more depth to the dialogue, but Eden is a pleasure to watch and contemplate.\",\"__typename\":\"Markdown\"},\"__typename\":\"ReviewText\"},\"title\":{\"id\":\"tt23149780\",\"__typename\":\"Title\"},\"authorRating\":8,\"spoiler\":false,\"__typename\":\"Review\"},\"__typename\":\"ReviewEdge\"},{\"node\":{\"id\":\"rw11128942\",\"author\":{\"userId\":\"ur176559064\",\"profileId\":\"p.vg45nbn3chdoeqfxzi6teq26j4\",\"username\":{\"text\":\"thevemir\",\"__typename\":\"UserProfileUsername\"},\"primaryImage\":null,\"__typename\":\"UserProfile\"},\"summary\":{\"originalText\":\"6.5/10\",\"__typename\":\"ReviewSummary\"},\"text\":{\"originalText\":{\"plaidHtml\":\"I was mostly interested in watching this film because of Ana de Armas, and only then because of the story.\\u003cbr/\\u003e\\u003cbr/\\u003eUnfortunately, the storyline about the main character searching for meaning and purpose isn\\u0026#39;t really explored. The film is much more about greed and animal instincts - every character betrays someone else for their own safety or selfish desires.\\u003cbr/\\u003e\\u003cbr/\\u003eThe runtime is quite long - 130 minutes - and this is not really a drama, but more of an arthouse film with a strong cast. I was engaged while watching it, especially after the halfway point when the tension really starts to build. The resolution is a bit unconventional, though I kind of expected it to go that way.\\u003cbr/\\u003e\\u003cbr/\\u003eThe budget is quite large for this genre (around $55 million), and as we know, the film completely flopped at the box office ($1.2 million). I don\\u0026#39;t know how it performed on streaming. And honestly - is this really a theatrical movie?\\u003cbr/\\u003e\\u003cbr/\\u003eThe biggest standout for me was Sydney Sweeney. Compared to some of her other roles, she delivers a much stronger and more interesting performance here. Ana de Armas is the jewel of the film (for me): she\\u0026#39;s captivating to watch, brings humor and dance to the screen, and overall performs very well - even if this isn\\u0026#39;t her best role, since she has many great ones already. Jude Law, Daniel Brühl, and Vanessa Kirby are also excellent.\\u003cbr/\\u003e\\u003cbr/\\u003eThe film is based on real events that happened about 100 years ago, which adds an extra layer of interest.\\u003cbr/\\u003e\\u003cbr/\\u003eOverall, it\\u0026#39;s worth a watch, but this is definitely not a movie for the masses - which explains why it failed financially. And let\\u0026#39;s be honest, this was never meant to be a box-office hit.\",\"__typename\":\"Markdown\"},\"__typename\":\"ReviewText\"},\"title\":{\"id\":\"tt23149780\",\"__typename\":\"Title\"},\"authorRating\":6,\"spoiler\":false,\"__typename\":\"Review\"},\"__typename\":\"ReviewEdge\"},{\"node\":{\"id\":\"rw10741594\",\"author\":{\"userId\":\"ur3588397\",\"profileId\":\"p.yskz6krth26ybuf6rdyrnrv7u4\",\"username\":{\"text\":\"drownsoda90\",\"__typename\":\"UserProfileUsername\"},\"primaryImage\":{\"image\":{\"url\":\"https://m.media-amazon.com/images/M/MV5BMjZmYTRlMjctZTk2YS00YWJlLWExM2EtYTFkNzA0MjlkNGY4XkEyXkFqcGc@._V1_.jpg\",\"height\":746,\"width\":746,\"caption\":{\"plainText\":\"Avatar\",\"__typename\":\"Markdown\"},\"__typename\":\"Image\"},\"__typename\":\"UserProfileImage\"},\"__typename\":\"UserProfile\"},\"summary\":{\"originalText\":\"Love thy neighbor\",\"__typename\":\"ReviewSummary\"},\"text\":{\"originalText\":{\"plaidHtml\":\"\\u0026quot;Eden\\u0026quot; focuses on a group of mostly German citizens who attempt to settle Floreana, an uninhabited island in the Galapagos after World War I. Their aim for a slice of paradise does not go as planned.\\u003cbr/\\u003e\\u003cbr/\\u003eNoah Pink\\u0026#39;s screenplay for the film is based on a true story (adapted from conflicting accounts written by two of the people who lived it) that almost seems unbelievable at times, except it\\u0026#39;s not--in fact, most of the details here are historically accurate, down to the individuals\\u0026#39; names, characterizations, and, more or less, the series of events that transpired. With that context in mind, it is worth noting that the events depicted here are perhaps not as outlandish as they may seem.\\u003cbr/\\u003e\\u003cbr/\\u003eThe film is directed by Ron Howard, who is known for his glossy big-budget films, and in that regard, \\u0026quot;Eden\\u0026quot; does not deviate too far from the director\\u0026#39;s norm, though the material is notably darker than the kind of fare Howard typically tackles. As often grey and drab is it looks, the film is well-shot and has an epic sort of look about it that audiences have come to expect from him.\\u003cbr/\\u003e\\u003cbr/\\u003eWhere the film perhaps suffers a bit is in the \\u0026quot;movie magic\\u0026quot; elements of a production like this, where the nitty gritty realities and sheer difficulty of homesteading on such an island feel glossed over at times. The actors often appear too clean, too rested (which for at least one of them, I suppose, makes senses) and too primped. This is a fine line to balance, as overindulging in the mintutaeua of homesteading and working a tropical landscape like this could become tedious, but a certain amount of it is necessary for the viewer to buy into the circumstances. There is never a significant sense that these people will succumb to the landscape-only to each other-and perhaps that may be the point.\\u003cbr/\\u003e\\u003cbr/\\u003eThe performances here are largely strong, with Jude Law and Vanessa Kirby playing the intellectual quasi-hippies who were the first to land on this hallowed ground. Daniel Brühl and Sydney Sweeney play a husband-and-wife who arrive and prove to be superior settlers with the the fundamental skills necessary to work the land; while they dedicate their bodies to harnessing the natural resources, the egomaniacal Law pontificates and philosophizes (obsessively quoting Nietzsche and other philosophers) his way through circumstances, with Kirby lending an effective performance as his multiple sclerosis-stricken lover. Ana de Armas gives an outrageous, campy turn as a self-described Baroness who lands on Floreana with grand ideas and a Clara Bow-esque posture, but no real means (intellectual, physical, or otherwise) of achieving any such fantasies. Instead, she utilizes her own sociopathy and manipulation tactics in a diabolical quest for control. I suspect that most of the performances here could be cited by some critics for overacting, but when stacked against the historical record, these depictions of such extreme personalities don\\u0026#39;t actually seem to be that far from the truth of who these individuals were. Sweeney and Brühl are perhaps the most believable simply because their characters are the most relatable, and their salt-of-the-earth nature prove to be a great asset in this conflict of personalities.\\u003cbr/\\u003e\\u003cbr/\\u003eEven for those not familiar with the actual story, there is some predicability here in terms of what will play out, but the funeral procession marches on in a manner that is no less engaging and attention-getting. In some regards, I think audiences will simultaneously expect more and less from this film. It never quite reaches the fever pitch we want, and yet the result remains largely satisfying. As with the performances, I suspect many of the critiques here will hinge on the mere facts of the story. Are these people outrageous? Yes. Does the story at times seem far-fetched? Sure. But as the old adage goes, oftentimes truth is stranger than fiction. 7/10.\",\"__typename\":\"Markdown\"},\"__typename\":\"ReviewText\"},\"title\":{\"id\":\"tt23149780\",\"__typename\":\"Title\"},\"authorRating\":7,\"spoiler\":false,\"__typename\":\"Review\"},\"__typename\":\"ReviewEdge\"},{\"node\":{\"id\":\"rw10622630\",\"author\":{\"userId\":\"ur59903387\",\"profileId\":\"p.kkkbxs5bavejsm2rff45who7s4\",\"username\":{\"text\":\"xnicofingerx\",\"__typename\":\"UserProfileUsername\"},\"primaryImage\":{\"image\":{\"url\":\"https://m.media-amazon.com/images/M/MV5BNzAxMTE3NjI3NF5BMl5BanBnXkFtZTgwMDc5MzM3MDI@._V1_.jpg\",\"height\":318,\"width\":318,\"caption\":{\"plainText\":\"Avatar\",\"__typename\":\"Markdown\"},\"__typename\":\"Image\"},\"__typename\":\"UserProfileImage\"},\"__typename\":\"UserProfile\"},\"summary\":{\"originalText\":\"Heaven was none and became hell\",\"__typename\":\"ReviewSummary\"},\"text\":{\"originalText\":{\"plaidHtml\":\"An extremely interesting story, based on true events, an accomplished director, a top cast, Hans Zimmer behind the score. A smash hit? At least not at the box office, the budget is not even close to being recouped. In terms of feeling, \\u0026#39;Eden\\u0026#39; was not represented in the media at all, apparently these days there is a lack of the muse to be caught up in realistic darkness and human abysses. The only partially resolved \\u0026#39;Galapagos Affair\\u0026#39; sheds light on the hopes and utopias of conquering a new land or escaping the old world in order to build an alternative civilisation there, and how human nature buries all dreams again. The supposed heaven turns into a hell of envy, jealousy, selfishness and vanity. Not forgetting the harsh reality of the supposed island paradise. All the supposed and proven events are almost unbelievable, which makes this survival trip all the more fascinating. A real true-crime story. The film adaptation does justice to this, the well-known cast performs excellently and there is little to criticise in terms of craftsmanship. The response does not do justice to the result, so I recommend it.\",\"__typename\":\"Markdown\"},\"__typename\":\"ReviewText\"},\"title\":{\"id\":\"tt23149780\",\"__typename\":\"Title\"},\"authorRating\":7,\"spoiler\":false,\"__typename\":\"Review\"},\"__typename\":\"ReviewEdge\"},{\"node\":{\"id\":\"rw10733221\",\"author\":{\"userId\":\"ur207299393\",\"profileId\":\"p.hk7nijngukauycyyvpxkjmjntm\",\"username\":{\"text\":\"DeeBro-2\",\"__typename\":\"UserProfileUsername\"},\"primaryImage\":null,\"__typename\":\"UserProfile\"},\"summary\":{\"originalText\":\"The human condition and trouble with others.\",\"__typename\":\"ReviewSummary\"},\"text\":{\"originalText\":{\"plaidHtml\":\"I went into this movie blind, it was a Monday Mystery Movie at Regal.\\u003cbr/\\u003e\\u003cbr/\\u003eIt\\u0026#39;s a philosophical journey of the human condition and the troubles that we have with each other. As the story unfolds you could definitely find something in it that resonates with the way you see the world. Finding out that this was based on a true story makes me want to read the two perspectives of what happened on the island. Not a bad movie, I think the critics might have been too critical of the movie.\",\"__typename\":\"Markdown\"},\"__typename\":\"ReviewText\"},\"title\":{\"id\":\"tt23149780\",\"__typename\":\"Title\"},\"authorRating\":7,\"spoiler\":false,\"__typename\":\"Review\"},\"__typename\":\"ReviewEdge\"}],\"__typename\":\"ReviewsConnection\"},\"isAdult\":false,\"moreLikeThisTitles\":{\"edges\":[{\"node\":{\"id\":\"tt27052633\",\"titleText\":{\"text\":\"Echo Valley\",\"__typename\":\"TitleText\"},\"titleType\":{\"id\":\"movie\",\"text\":\"Movie\",\"canHaveEpisodes\":false,\"displayableProperty\":{\"value\":{\"plainText\":\"\",\"__typename\":\"Markdown\"},\"__typename\":\"DisplayableTitleTypeProperty\"},\"__typename\":\"TitleType\"},\"originalTitleText\":{\"text\":\"Echo Valley\",\"__typename\":\"TitleText\"},\"primaryImage\":{\"id\":\"rm2623702530\",\"width\":2000,\"height\":3000,\"url\":\"https://m.media-amazon.com/images/M/MV5BN2RmMTUzY2YtYTBlZC00OTVhLWE0YTEtMmU3OGY5YWM2NjhhXkEyXkFqcGc@._V1_.jpg\",\"caption\":{\"plainText\":\"Julianne Moore and Sydney Sweeney in Echo Valley (2025)\",\"__typename\":\"Markdown\"},\"__typename\":\"Image\"},\"releaseYear\":{\"year\":2025,\"endYear\":null,\"__typename\":\"YearRange\"},\"ratingsSummary\":{\"aggregateRating\":6.2,\"voteCount\":23572,\"__typename\":\"RatingsSummary\"},\"runtime\":{\"seconds\":6240,\"__typename\":\"Runtime\"},\"certificate\":{\"rating\":\"R\",\"__typename\":\"Certificate\"},\"canRate\":{\"isRatable\":true,\"__typename\":\"CanRate\"},\"titleGenres\":{\"genres\":[{\"genre\":{\"text\":\"Drama\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"},{\"genre\":{\"text\":\"Thriller\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"}],\"__typename\":\"TitleGenres\"},\"__typename