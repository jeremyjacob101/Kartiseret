y\"},\"runtime\":{\"seconds\":5700,\"__typename\":\"Runtime\"},\"certificate\":{\"rating\":\"R\",\"__typename\":\"Certificate\"},\"canRate\":{\"isRatable\":true,\"__typename\":\"CanRate\"},\"titleGenres\":{\"genres\":[{\"genre\":{\"text\":\"Action\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"},{\"genre\":{\"text\":\"Thriller\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"}],\"__typename\":\"TitleGenres\"},\"__typename\":\"Title\"},\"__typename\":\"MoreLikeThisEdge\"},{\"node\":{\"id\":\"tt23137390\",\"titleText\":{\"text\":\"Immaculate\",\"__typename\":\"TitleText\"},\"titleType\":{\"id\":\"movie\",\"text\":\"Movie\",\"canHaveEpisodes\":false,\"displayableProperty\":{\"value\":{\"plainText\":\"\",\"__typename\":\"Markdown\"},\"__typename\":\"DisplayableTitleTypeProperty\"},\"__typename\":\"TitleType\"},\"originalTitleText\":{\"text\":\"Immaculate\",\"__typename\":\"TitleText\"},\"primaryImage\":{\"id\":\"rm3214429441\",\"width\":1383,\"height\":2048,\"url\":\"https://m.media-amazon.com/images/M/MV5BMWEzYjYyMjQtNTJjYi00ZDQ5LWE4N2MtNWY2ZTgxODNhYWM4XkEyXkFqcGc@._V1_.jpg\",\"caption\":{\"plainText\":\"Sydney Sweeney in Immaculate (2024)\",\"__typename\":\"Markdown\"},\"__typename\":\"Image\"},\"releaseYear\":{\"year\":2024,\"endYear\":null,\"__typename\":\"YearRange\"},\"ratingsSummary\":{\"aggregateRating\":5.8,\"voteCount\":60991,\"__typename\":\"RatingsSummary\"},\"runtime\":{\"seconds\":5340,\"__typename\":\"Runtime\"},\"certificate\":{\"rating\":\"R\",\"__typename\":\"Certificate\"},\"canRate\":{\"isRatable\":true,\"__typename\":\"CanRate\"},\"titleGenres\":{\"genres\":[{\"genre\":{\"text\":\"Horror\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"},{\"genre\":{\"text\":\"Thriller\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"}],\"__typename\":\"TitleGenres\"},\"__typename\":\"Title\"},\"__typename\":\"MoreLikeThisEdge\"},{\"node\":{\"id\":\"tt26625693\",\"titleText\":{\"text\":\"The Order\",\"__typename\":\"TitleText\"},\"titleType\":{\"id\":\"movie\",\"text\":\"Movie\",\"canHaveEpisodes\":false,\"displayableProperty\":{\"value\":{\"plainText\":\"\",\"__typename\":\"Markdown\"},\"__typename\":\"DisplayableTitleTypeProperty\"},\"__typename\":\"TitleType\"},\"originalTitleText\":{\"text\":\"The Order\",\"__typename\":\"TitleText\"},\"primaryImage\":{\"id\":\"rm9068801\",\"width\":2025,\"height\":3000,\"url\":\"https://m.media-amazon.com/images/M/MV5BZWIxOGQyYjYtOGEwOC00YWNjLWJmNTktZjJlM2RmNTdjMmVlXkEyXkFqcGc@._V1_.jpg\",\"caption\":{\"plainText\":\"Jude Law, Nicholas Hoult, Jurnee Smollett, and Tye Sheridan in The Order (2024)\",\"__typename\":\"Markdown\"},\"__typename\":\"Image\"},\"releaseYear\":{\"year\":2024,\"endYear\":null,\"__typename\":\"YearRange\"},\"ratingsSummary\":{\"aggregateRating\":6.8,\"voteCount\":62495,\"__typename\":\"RatingsSummary\"},\"runtime\":{\"seconds\":6960,\"__typename\":\"Runtime\"},\"certificate\":{\"rating\":\"R\",\"__typename\":\"Certificate\"},\"canRate\":{\"isRatable\":true,\"__typename\":\"CanRate\"},\"titleGenres\":{\"genres\":[{\"genre\":{\"text\":\"Crime\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"},{\"genre\":{\"text\":\"Drama\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"},{\"genre\":{\"text\":\"Thriller\",\"__typename\":\"GenreItem\"},\"__typename\":\"TitleGenre\"}],\"__typename\":\"TitleGenres\"},\"__typename\":\"Title\"},\"__typename\":\"MoreLikeThisEdge\"},{\"node\":{\"id\":\"tt2180339\",\"titleText\":{\"text\":\"Deep Water\",\"__typename\":\"TitleText\"},\"titleType\":{\"id\":\"movie\",\"text\":\"Movie\",\"canHaveEpisodes\":false,\"displayableProperty\":{\"value\":{\"plainText\":\"\",\"__typename\":\"Markdown\"},\"__typename\":\"DisplayableTitleTypeProperty\"},\"__typename\":\"TitleType\"},\"originalTitleText\":{\"text\":\"Deep Water\",\"__typename\":\"TitleText\"},\"primaryImage\":{\"id\":\"rm4045347329\",\"width\":2025,\"height\":3000,\"url\":\"https://m.media-amazon.com/images/M/MV5BZWNkNGU